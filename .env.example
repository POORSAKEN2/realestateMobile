# Expo Project ID
EXPO_PROJECT_ID=

# API Base URL
# Use VITE_API_BASE_URL for web/vite environments
VITE_API_BASE_URL=http://localhost:8000/api
# Use EXPO_PUBLIC_API_BASE_URL for Expo Go / Native environments
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Apple Maps WebView bridge (Android)
# Token must be authorized for EXPO_PUBLIC_MAPKIT_JS_BASE_URL in Apple Developer.
EXPO_PUBLIC_MAPKIT_JS_TOKEN=
EXPO_PUBLIC_MAPKIT_JS_BASE_URL=https://your-authorized-map-domain.example
