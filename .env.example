# Expo Project ID
EXPO_PROJECT_ID=

# API Base URL
# Use VITE_API_BASE_URL for web/vite environments
VITE_API_BASE_URL=http://localhost:8000/api
# Use EXPO_PUBLIC_API_BASE_URL for Expo Go / Native environments
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000/api

# Google Maps SDK for Android (required by react-native-maps in Android builds)
GOOGLE_MAPS_API_KEY=

# Optional: replace the public OpenStreetMap Nominatim search service.
EXPO_PUBLIC_GEOCODING_BASE_URL=https://nominatim.openstreetmap.org
